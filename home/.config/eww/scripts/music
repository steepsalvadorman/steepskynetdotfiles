#!/bin/bash

# Intenta detectar cualquier reproductor activo (navegador, Spotify, mpd, etc)
PLAYER=$(playerctl -l 2>/dev/null | head -1)
PLAYER=${PLAYER:-"spotify"}

case "$1" in

    --title)
        playerctl -p "$PLAYER" metadata title 2>/dev/null \
            || echo "Sin reproducción"
        ;;

    --artist)
        playerctl -p "$PLAYER" metadata artist 2>/dev/null
        ;;

    --status)

        status=$(playerctl -p "$PLAYER" status 2>/dev/null)

        case "$status" in
            Playing)
                echo "󰏤"
                ;;
            *)
                echo "󰐊"
                ;;
        esac
        ;;

    --cover)

        url=$(playerctl -p "$PLAYER" metadata mpris:artUrl 2>/dev/null)

        if [[ "$url" == file://* ]]; then
            echo "${url#file://}"
        else
            echo "$url"
        fi
        ;;

    --next)
        playerctl -p "$PLAYER" next
        ;;

    --previous)
        playerctl -p "$PLAYER" previous
        ;;

    --toggle)
        playerctl -p "$PLAYER" play-pause
        ;;

esac
