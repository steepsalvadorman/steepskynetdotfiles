#!/bin/bash
# Estado de OBS detectando proceso y grabación/streaming

is_running() {
    pgrep -x obs > /dev/null 2>&1
}

is_recording() {
    obs-cmd --websocket obsws://localhost:4455 recording status 2>/dev/null \
        | grep -q '"outputActive":true' && return 0
    return 1
}

is_streaming() {
    obs-cmd --websocket obsws://localhost:4455 streaming status 2>/dev/null \
        | grep -q '"outputActive":true' && return 0
    return 1
}

case "$1" in
    --status)
        if ! is_running; then
            echo "inactivo"
        elif is_recording; then
            echo "grabando"
        elif is_streaming; then
            echo "transmitiendo"
        else
            echo "abierto"
        fi
        ;;
    --icon)
        echo "󰐸"
        ;;
    --color)
        if ! is_running; then
            echo "#9499ad"   # gris plata — inactivo
        else
            echo "#3c3836"   # carbón oscuro — activo
        fi
        ;;
    --active)
        if is_recording || is_streaming; then
            echo "true"
        else
            echo "false"
        fi
        ;;
esac
