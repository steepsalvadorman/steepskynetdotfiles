#!/usr/bin/env bash

PROJECTS_DIR="$HOME/Documentos/programacion"
EWW_CLOSE="eww -c /home/steepskynet/.config/eww close projects-popup"

declare -A LANG_ICONS=(
    ["Python"]="󰌠"
    ["rust"]="󱘗"
    ["readme"]="󰈙"
)

declare -A LANG_LABELS=(
    ["Python"]="Python"
    ["rust"]="Rust"
    ["readme"]="Docs"
)

out='(box :orientation "v" :space-evenly false :spacing 0 :class "projects-list"'
out+=' (label :class "projects-header" :text " Proyectos" :halign "start")'

for lang_dir in "$PROJECTS_DIR"/*/; do
    [ -d "$lang_dir" ] || continue
    lang=$(basename "$lang_dir")
    icon="${LANG_ICONS[$lang]:-󰉋}"
    label="${LANG_LABELS[$lang]:-$lang}"

    out+=" (box :class \"projects-section\" :orientation \"v\" :space-evenly false :spacing 2"
    out+="   (label :class \"projects-lang\" :text \"${icon}  ${label}\" :halign \"start\")"

    if [ -d "${lang_dir}.git" ]; then
        proj_path="${lang_dir%/}"
        out+="   (button :class \"project-btn\""
        out+="     :onclick \"code ${proj_path} & ${EWW_CLOSE}\""
        out+="     (label :class \"project-name\" :text \"  ${lang}\" :halign \"start\"))"
    else
        for proj_dir in "${lang_dir}"*/; do
            [ -d "$proj_dir" ] || continue
            proj=$(basename "$proj_dir")
            proj_path="${proj_dir%/}"
            out+="   (button :class \"project-btn\""
            out+="     :onclick \"code ${proj_path} & ${EWW_CLOSE}\""
            out+="     (label :class \"project-name\" :text \"  ${proj}\" :halign \"start\"))"
        done
    fi

    out+=" )"
done

out+=")"
echo "$out"
