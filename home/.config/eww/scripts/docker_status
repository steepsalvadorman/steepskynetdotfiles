#!/bin/bash
# Estado de contenedores Docker

count=$(docker ps --format '{{.ID}}' 2>/dev/null | wc -l)

case "$1" in
    --count)
        echo "$count"
        ;;
    --icon)
        echo "󰡨"
        ;;
    --color)
        if [ "$count" -gt 0 ]; then
            echo "#8ec07c"   # aqua-bright — contenedores corriendo
        else
            echo "#504945"   # gris — sin contenedores
        fi
        ;;
esac
