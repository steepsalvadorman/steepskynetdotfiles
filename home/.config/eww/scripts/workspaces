#!/bin/bash

active=$(hyprctl activeworkspace -j | jq '.id')
existing=$(hyprctl workspaces -j | jq '.[].id' | sort -n)
highest=$(echo "$existing" | tail -n 1)
[ -z "$highest" ] && highest=2
[ "$highest" -lt 2 ] && highest=2
[ "$highest" -gt 10 ] && highest=10
occupied=$(hyprctl clients -j | jq '[.[].workspace.id]')

accent=$(cat ~/.cache/wal/eww-accent.txt 2>/dev/null || echo "#B4D13A")

echo -n '(box :class "ws-box" :space-evenly false :spacing 4'

for ((i=1; i<=highest; i++)); do
    if [ "$i" -eq "$active" ]; then
        echo -n " (button
            :class \"workspace-entry current\"
            :style \"background: ${accent};\"
            :onclick \"hyprctl dispatch workspace $i\"
            \"$i\")"
    elif echo "$occupied" | jq -e "contains([$i])" >/dev/null 2>&1; then
        echo -n " (button
            :class \"workspace-entry occupied\"
            :onclick \"hyprctl dispatch workspace $i\"
            \"$i\")"
    else
        echo -n " (button
            :class \"workspace-entry empty\"
            :onclick \"hyprctl dispatch workspace $i\"
            \"$i\")"
    fi
done

echo ')'
