#!/bin/bash
# Conteo de notificaciones via swaync

count=$(swaync-client -c 2>/dev/null | jq '.count // 0' 2>/dev/null || echo "0")

case "$1" in
    --count)
        echo "$count"
        ;;
    --color)
        if [ "$count" -gt 5 ]; then
            echo "#fb4934"   # rojo — muchas notifs
        elif [ "$count" -gt 0 ]; then
            echo "#fabd2f"   # amarillo — algunas
        else
            echo "#504945"   # gris — ninguna
        fi
        ;;
esac
